  // Root.sc.html is parsed as JSX so the whitespace between slide elements
  // becomes string children. Filter those out — otherwise slides.length is
  // ~2x the real count and the n/total counter goes haywire.
  const slides = React.Children.toArray(children).filter(
    (c) => typeof c !== 'string' || c.trim() !== '',
  );
  const [idx, setIdx] = React.useState(0);
  const userTookControl = React.useRef(false);
  const prevCount = React.useRef(slides.length);

  // Fit the 1280x720 stage to the viewport with letterboxing. ResizeObserver
  // on the outer fixed container so we react to window resizes and any
  // parent layout changes. Allow scaling above 1 — slides should fill.
  const outerRef = React.useRef(null);
  const [scale, setScale] = React.useState(1);
  React.useEffect(() => {
    const el = outerRef.current;
    if (!el) return;
    const update = () => {
      const w = el.clientWidth;
      const h = el.clientHeight;
      if (!w || !h) return;
      setScale(Math.min(w / 1280, h / 720));
    };
    update();
    const ro = new ResizeObserver(update);
    ro.observe(el);
    return () => ro.disconnect();
  }, []);

  // During streaming the model is writing slide N while the user is
  // looking at slide 1. Auto-advance to the tail until the user grabs
  // control, so they see the new content as it arrives.
  React.useEffect(() => {
    if (slides.length > prevCount.current && !userTookControl.current) {
      setIdx(slides.length - 1);
    }
    prevCount.current = slides.length;
  }, [slides.length]);

  const total = slides.length || 1;
  const safeIdx = Math.max(0, Math.min(idx, total - 1));

  const go = React.useCallback(
    (next) => {
      userTookControl.current = true;
      setIdx(Math.max(0, Math.min(total - 1, next)));
    },
    [total],
  );

  React.useEffect(() => {
    const onKey = (e) => {
      if (e.key === 'ArrowLeft') go(safeIdx - 1);
      else if (e.key === 'ArrowRight' || e.key === ' ') go(safeIdx + 1);
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [safeIdx, go]);

  return (
    <div
      ref={outerRef}
      style={{
        position: 'fixed',
        inset: 0,
        background: '#f0f0f0',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontFamily: 'system-ui',
      }}
    >
      <div
        style={{
          width: 1280,
          height: 720,
          background: 'white',
          borderRadius: 12,
          boxShadow: '0 20px 60px rgba(0,0,0,0.15)',
          position: 'relative',
          overflow: 'hidden',
          transform: \`scale(\${scale})\`,
          transformOrigin: 'center center',
          flexShrink: 0,
        }}
      >
        {slides.map((child, i) => (
          <div
            key={i}
            style={{
              position: 'absolute',
              inset: 0,
              display: i === safeIdx ? 'flex' : 'none',
              alignItems: 'center',
              justifyContent: 'center',
            }}
          >
            {child}
          </div>
        ))}
        <div
          style={{
            position: 'absolute',
            bottom: 24,
            left: '50%',
            transform: 'translateX(-50%)',
            display: 'flex',
            alignItems: 'center',
            gap: 12,
            background: 'rgba(0,0,0,0.6)',
            backdropFilter: 'blur(8px)',
            WebkitBackdropFilter: 'blur(8px)',
            color: 'white',
            padding: '8px 16px',
            borderRadius: 24,
            fontSize: 13,
          }}
        >
          <button
            onClick={() => go(safeIdx - 1)}
            style={{
              background: 'transparent',
              border: 'none',
              color: 'white',
              cursor: 'pointer',
              fontSize: 18,
              padding: '0 4px',
            }}
          >
            ←
          </button>
          <span style={{ fontVariantNumeric: 'tabular-nums', minWidth: 48, textAlign: 'center' }}>
            {safeIdx + 1} / {total}
          </span>
          <button
            onClick={() => go(safeIdx + 1)}
            style={{
              background: 'transparent',
              border: 'none',
              color: 'white',
              cursor: 'pointer',
              fontSize: 18,
              padding: '0 4px',
            }}
          >
            →
          </button>
        </div>
      </div>
    </div>
  );
}
module.exports = { default: Slides };
`,E6=`function Canvas({ children }) {
  // Root.sc.html JSX includes whitespace text nodes between frame elements;
  // they'd render as stray text inside the world layer. Filter them out.
  const frames = React.Children.toArray(children).filter(
    (c) => typeof c !== 'string' || c.trim() !== '',
  );
  const [view, setView] = React.useState({ scale: 1, x: 0, y: 0 });
  const [panning, setPanning] = React.useState(false);
  const rootRef = React.useRef(null);
  const panStart = React.useRef(null);

  React.useEffect(() => {
    const el = rootRef.current;
    if (!el) return;
    const handler = (e) => {
      e.preventDefault();
      // Trackpad pinch-zoom synthesizes ctrlKey=true (even when the key
      // isn't held), so ctrlKey is the zoom gate. Everything else —
      // trackpad two-finger scroll or a physical mouse wheel — pans by
      // deltaX/deltaY. Hold ctrl (or cmd on macOS) + wheel to zoom with a
      // mouse.
      if (!e.ctrlKey && !e.metaKey) {
        setView((v) => ({ ...v, x: v.x - e.deltaX, y: v.y - e.deltaY }));
        return;
      }
      setView((v) => {
        // Clamp deltaY so a single ctrl+wheel notch (~±100px) doesn't jump
        // ~2.7× per event; capped at ±50 → ~1.65× max. Trackpad pinch deltas
        // are well inside this range and unaffected.
        const dy = Math.max(-50, Math.min(50, e.deltaY));
        const factor = Math.exp(-dy * 0.01);
        const newScale = Math.max(0.1, Math.min(5, v.scale * factor));
        const rect = el.getBoundingClientRect();
        const mx = e.clientX - rect.left;
        const my = e.clientY - rect.top;
        // keep the world point under the cursor fixed across the zoom
        const newX = mx - (mx - v.x) * (newScale / v.scale);
        const newY = my - (my - v.y) * (newScale / v.scale);
        return { scale: newScale, x: newX, y: newY };
      });
    };
    el.addEventListener('wheel', handler, { passive: false });
    return () => el.removeEventListener('wheel', handler);
  }, []);

  const onMouseDown = (e) => {
    if (e.button !== 0) return;
    // Only pan when the mousedown lands on the canvas background itself.
    // Mousedowns on a child frame must fall through so the frame's own
    // click/drag handlers work — otherwise the canvas eats every gesture on
    // top of content. currentTarget is the root div (this handler is bound
    // to it); target is the deepest element the mouse hit.
    if (e.target !== e.currentTarget) return;
    panStart.current = { mx: e.clientX, my: e.clientY, sx: view.x, sy: view.y };
    setPanning(true);
    const onMove = (ev) => {
      if (!panStart.current) return;
      const dx = ev.clientX - panStart.current.mx;
      const dy = ev.clientY - panStart.current.my;
      setView((v) => ({ ...v, x: panStart.current.sx + dx, y: panStart.current.sy + dy }));
    };
    const onUp = () => {
      panStart.current = null;
      setPanning(false);
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
    };
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onUp);
  };

  return (
    <div
      ref={rootRef}
      onMouseDown={onMouseDown}
      style={{
        position: 'fixed',
        inset: 0,
        overflow: 'hidden',
        backgroundColor: '#fafafa',
        backgroundImage: 'radial-gradient(#e0e0e0 1px,transparent 1px)',
        backgroundSize: '24px 24px',
        cursor: panning ? 'grabbing' : 'grab',
        fontFamily: 'system-ui',
      }}
    >
      <div
        style={{
          position: 'absolute',
          width: 0,
          height: 0,
          transform: \`translate(\${view.x}px, \${view.y}px) scale(\${view.scale})\`,
          transformOrigin: '0 0',
        }}
      >
        {frames}
      </div>
    </div>
  );
}
module.exports = { default: Canvas };
