{
  "name": "gignow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:types": "tsc --noEmit",
    "test:lint": "eslint .",
    "db:supabase": "tsx scripts/apply-supabase-migrations.ts",
    "review": "tsx scripts/review/run-review.ts",
    "review:full-sweep": "REVIEW_RUN=1 tsx scripts/review/run-full-sweep.ts",
    "review:stack": "tsx scripts/review/start-local-stack.ts",
    "review:seed": "tsx scripts/review/seed-test-data.ts",
    "review:smoke": "REVIEW_RUN=1 tsx scripts/review/review-runner.ts --route=/",
    "review:quality": "npm run test:types && npm run test:lint && npm run test -- --run",
    "check:no-mock": "node scripts/check-no-mock-imports.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.95.2",
    "ai": "^6.0.154",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.0.2",
    "supabase": "^2.93.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
