# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
tests/.supabase-connectivity.json
/test-results
/playwright-report
/.playwright-mcp

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 브라우저 다운로드 형태의 env 파일 (`env.download`, `env (1).download` 등)
env*.download
*env*.download

# vercel
.vercel

# claude code worktrees scratch dir (gsd workflow temp)
.claude/

# impeccable/skills runner mirrors — canonical location is .agents/skills/.
# Claude Code and OpenClaw read from /skills via symlink; on Windows git
# dereferences symlinks into duplicate files, so we ignore the mirror.
/skills/
skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.vercel
.gstack/

# Legacy design/prototype files (BUG-C04)
_design_review/
src/_legacy/
salaryjob*.html
salaryjob*.zip
salaryjob*_files/
