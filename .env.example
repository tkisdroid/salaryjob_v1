# GigNow Phase 2 — environment template
# Copy to .env.local and fill in values from Supabase Dashboard

# ============================================================================
# Supabase — public (safe to expose in client bundle)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Backward-compat alias — set to same value as PUBLISHABLE_KEY during transition
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ============================================================================
# Supabase — server-only (NEVER commit, NEVER expose to client)
# ============================================================================
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Connection via Supavisor transaction pooler (port 6543) — for runtime queries
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (port 5432) — required by `prisma migrate dev` per RESEARCH.md §Key Finding #6
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ============================================================================
# OAuth (Plan 04 Google, Plan 06 Kakao)
# ============================================================================
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_KAKAO_CLIENT_ID=
SUPABASE_AUTH_KAKAO_SECRET=

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Seed (Plan 05) — optional override
# ============================================================================
SEED_DEV_PASSWORD=gignowdev

# ============================================================================
# Naver Maps JavaScript v3 (NCP) — Web Dynamic Map Client ID
# ============================================================================
# Issue at https://console.ncloud.com → Services → AI·Application Service →
#   Maps → Application 등록 → Web Dynamic Map 체크 → Client ID 발급
# Register http://localhost:3000 and the production domain under
#   "서비스 환경 등록 > Web 서비스 URL".
# Reference: https://navermaps.github.io/maps.js.ncp/docs/tutorial-2-Getting-Started.html
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# ============================================================================
# Phase 4 — Web Push VAPID keys (D-19, D-20)
# ============================================================================
# Generate once: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Optional — RFC 8292 subject (mailto: or https:) sent with every push request
WEB_PUSH_VAPID_SUBJECT=mailto:dev@gignow.local
# Same value as WEB_PUSH_VAPID_PUBLIC_KEY — must be NEXT_PUBLIC_ so the browser
# can pass it to PushManager.subscribe({ applicationServerKey }).
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# ============================================================================
# Phase 4 — Checkout QR JWT signing secret (D-15)
# ============================================================================
# 32-byte hex random, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
APPLICATION_JWT_SECRET=

# ============================================================================
# Phase 6 — Admin backoffice & OCR
# ============================================================================
# Naver CLOVA OCR General (biz license extraction) — https://guide.ncloud-docs.com/docs/en/clovaocr-overview
# Leave blank to disable OCR (D-33 graceful degradation: image still saves, admin review flag set)
# Provisioning guide: docs/external-keys.md §CLOVA OCR
CLOVA_OCR_SECRET=
CLOVA_OCR_API_URL=
# Platform commission rate default, percentage form (e.g. "5.00" means 5%). Empty/unset = 0%.
PLATFORM_DEFAULT_COMMISSION_RATE=0

# ============================================================================
# Naver Cloud Platform — SENS SMS (대표자 연락처 OTP 인증)
# ============================================================================
# Docs: https://guide.ncloud-docs.com/docs/sens-overview
# 발급 순서:
#   1. NCP 콘솔 로그인 → AI·Application Service → Simple & Easy Notification Service
#   2. Project (SMS) 생성 → Service ID 확인 (UUID 형식)
#   3. 발신번호 등록 → 인증 완료된 번호만 사용 가능
#   4. 우측 상단 계정 메뉴 → 인증키 관리 → Access Key / Secret Key 발급
NCP_SENS_SERVICE_ID=
NCP_SENS_ACCESS_KEY=
NCP_SENS_SECRET_KEY=
NCP_SENS_FROM=
# Dev 환경에서 실제 SMS를 보내지 않고 OTP 코드를 서버 로그에 출력만 하려면 on (기본).
# 운영 배포 시 off로 두거나 NODE_ENV=production 이어야 실제 발송.
NCP_SENS_TESTMODE=on
