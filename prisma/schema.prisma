// GigNow Platform - Prisma Schema
// Short-term gig work matching platform

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  WORKER
  EMPLOYER
  BOTH
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BadgeLevel {
  NEWBIE
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum TransportType {
  PUBLIC
  CAR
  MOTORCYCLE
  BICYCLE
  WALK
}

enum PartnershipLevel {
  NORMAL
  SILVER
  GOLD
  PLATINUM
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

enum TagType {
  SYSTEM
  USER
}

enum PostType {
  JOB_OFFER
  JOB_SEEK
  FREE
}

enum LocationType {
  ONSITE
  REMOTE
  ONLINE
  HYBRID
  NEGOTIABLE
  TRAVEL
}

enum ScheduleType {
  SPECIFIC
  PERIOD
  RECURRING
  ALWAYS
  FLEXIBLE
}

enum PayType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  PER_TASK
  TOTAL
  NEGOTIABLE
  VOLUNTEER
}

enum SettlementType {
  IMMEDIATE
  DAILY
  WEEKLY
  MONTHLY
  NEGOTIABLE
}

enum GenderPreference {
  MALE
  FEMALE
  ANY
}

enum ExperienceLevel {
  NONE
  BEGINNER
  INTERMEDIATE
  EXPERT
  ANY
}

enum PostStatus {
  DRAFT
  ACTIVE
  PAUSED
  FILLED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PostVisibility {
  PUBLIC
  PRIVATE
  LINK_ONLY
}

enum AutoCloseType {
  MANUAL
  DATE
  HEADCOUNT
}

enum ApplicationDirection {
  APPLY
  REVERSE_OFFER
  TASK_REQUEST
  MUTUAL
}

enum ApplicationStatus {
  PENDING
  VIEWED
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  COMPLETED
  NO_SHOW
  DISPUTED
}

enum SettlementStatus {
  CHECKOUT_PENDING
  APPROVED
  AUTO_APPROVED
  PROCESSING
  SETTLED
  RETRY_1
  RETRY_2
  RETRY_3
  FAILED
}

enum VerificationStatus {
  PENDING
  PROCESSING
  VERIFIED
  REJECTED_CLOSED
  REJECTED_MISMATCH
  SUSPENDED
  EXPIRED
}

enum ChatMessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  LOCATION
}

enum NotificationChannel {
  IN_APP
  PUSH
  SMS
  EMAIL
}

enum MediaType {
  PROFILE_PHOTO
  PORTFOLIO
  CERTIFICATE
  ID_DOCUMENT
  OTHER
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum MediaStatus {
  PROCESSING
  ACTIVE
  DELETED
  ERROR
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String?    @unique
  phone        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workerProfile        WorkerProfile?
  employerProfile      EmployerProfile?
  businessVerifications BusinessVerification[]
  posts                Post[]
  applications         Application[]
  reviewsGiven         Review[]               @relation("ReviewerReviews")
  reviewsReceived      Review[]               @relation("RevieweeReviews")
  chatMessages         ChatMessage[]
  notifications        Notification[]
  userSkillTags        UserSkillTag[]
  userMedia            UserMedia[]
  postComments         PostComment[]

  @@map("users")
}

model WorkerProfile {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @unique @db.Uuid
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  nickname            String?
  birthDate           DateTime?
  gender              Gender?
  bio                 String?       @db.VarChar(140)
  description         String?
  address             String?
  addressLat          Decimal?      @db.Decimal(10, 7)
  addressLng          Decimal?      @db.Decimal(10, 7)
  preferredCategories Json          @default("[]")
  preferredRegions    Json          @default("[]")
  preferredPayMin     Int?
  preferredPayMax     Int?
  preferredPayUnit    String?
  preferredWorkTypes  Json          @default("[]")
  transportType       TransportType @default(PUBLIC)
  languages           Json          @default("[\"ko\"]")
  equipment           Json          @default("[]")
  snsLinks            Json          @default("[]")
  verificationLevel   Int           @default(1)
  badgeLevel          BadgeLevel    @default(NEWBIE)
  avgRating           Decimal       @default(0) @db.Decimal(3, 2)
  totalJobsCompleted  Int           @default(0)
  noShowCount         Int           @default(0)
  profileCompleteness Int           @default(0)
  bankName            String?
  bankAccount         String?
  bankHolder          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  availabilities  WorkerAvailability[]
  settlements     Settlement[]
  chatRooms       ChatRoom[]         @relation("WorkerChatRooms")
  favoriteByEmployers FavoriteWorker[]

  @@index([addressLat, addressLng])
  @@map("worker_profiles")
}

model EmployerProfile {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @unique @db.Uuid
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  businessRegNumber  String           @unique
  representativeName String
  businessCategory   String?
  address            String
  addressLat         Decimal          @db.Decimal(10, 7)
  addressLng         Decimal          @db.Decimal(10, 7)
  contactName        String?
  contactPhone       String?
  contactEmail       String?
  description        String?
  logoUrl            String?
  photos             Json             @default("[]")
  operatingHours     Json?
  isVerified         Boolean          @default(false)
  partnershipLevel   PartnershipLevel @default(NORMAL)
  avgRating          Decimal          @default(0) @db.Decimal(3, 2)
  commissionRate     Decimal          @default(10) @db.Decimal(5, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  settlements     Settlement[]
  chatRooms       ChatRoom[]       @relation("EmployerChatRooms")
  favoriteWorkers FavoriteWorker[]

  @@map("employer_profiles")
}

model BusinessVerification {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @db.Uuid
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessNumber       String
  representativeName   String
  startDate            DateTime
  businessName         String
  businessType         String?
  businessItem         String?
  registrationImageUrl String
  ntsStatusCode        String?
  ntsStatusText        String?
  ntsTaxType           String?
  ntsValidationMatch   Boolean?
  ntsRawResponse       Json?
  verificationStatus   VerificationStatus @default(PENDING)
  lastRecheckAt        DateTime?
  nextRecheckAt        DateTime?
  recheckCount         Int                @default(0)
  adminNote            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  verifiedAt           DateTime?

  @@map("business_verifications")
}

model WorkerAvailability {
  id                String             @id @default(uuid()) @db.Uuid
  workerId          String             @db.Uuid
  worker            WorkerProfile      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  startAt           DateTime
  endAt             DateTime
  status            AvailabilityStatus @default(AVAILABLE)
  preferredCategory String?
  minHourlyRate     Int?
  maxDistanceKm     Int                @default(5)
  isRecurring       Boolean            @default(false)
  recurringPattern  Json?
  createdAt         DateTime           @default(now())

  @@index([workerId, startAt])
  @@index([status, startAt, endAt])
  @@map("worker_availabilities")
}

model Tag {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  slug       String   @unique
  type       TagType  @default(SYSTEM)
  category   String?
  usageCount Int      @default(0)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  posts         PostTag[]
  userSkillTags UserSkillTag[]

  @@index([name])
  @@index([usageCount(sort: Desc)])
  @@map("tags")
}

model Post {
  id                String         @id @default(uuid()) @db.Uuid
  authorId          String         @db.Uuid
  author            User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postType          PostType
  title             String
  content           String?
  contentPlain      String?
  images            Json           @default("[]")
  videos            Json           @default("[]")
  attachments       Json           @default("[]")
  locationType      LocationType
  address           String?
  addressDetail     String?
  lat               Decimal?       @db.Decimal(10, 7)
  lng               Decimal?       @db.Decimal(10, 7)
  scheduleType      ScheduleType
  workDates         Json?
  startTime         String?
  endTime           String?
  periodStart       DateTime?
  periodEnd         DateTime?
  recurringPattern  Json?
  payType           PayType
  payAmountMin      Int?
  payAmountMax      Int?
  payBenefits       Json           @default("[]")
  payDescription    String?
  settlementType    SettlementType @default(NEGOTIABLE)
  headcount         Int?
  genderPref        GenderPreference @default(ANY)
  ageMin            Int?
  ageMax            Int?
  experienceLevel   ExperienceLevel  @default(ANY)
  requirements      String?
  customQuestions   Json           @default("[]")
  status            PostStatus     @default(DRAFT)
  visibility        PostVisibility @default(PUBLIC)
  isUrgent          Boolean        @default(false)
  isPremium         Boolean        @default(false)
  autoCloseType     AutoCloseType  @default(MANUAL)
  autoCloseDate     DateTime?
  viewsCount        Int            @default(0)
  savesCount        Int            @default(0)
  applicationsCount Int            @default(0)
  commentsCount     Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  expiresAt         DateTime?

  tags         PostTag[]
  applications Application[]
  comments     PostComment[]

  @@index([postType, status, createdAt(sort: Desc)])
  @@index([isUrgent, isPremium])
  @@index([status, createdAt(sort: Desc)])
  @@index([lat, lng])
  @@index([authorId])
  @@map("posts")
}

model PostTag {
  postId String  @db.Uuid
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String  @db.Uuid
  tag    Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  isAuto Boolean @default(false)

  @@unique([postId, tagId])
  @@map("post_tags")
}

model UserSkillTag {
  userId     String  @db.Uuid
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId      String  @db.Uuid
  tag        Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  isVerified Boolean @default(false)

  @@unique([userId, tagId])
  @@map("user_skill_tags")
}

model Application {
  id                 String              @id @default(uuid()) @db.Uuid
  postId             String              @db.Uuid
  post               Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  applicantId        String              @db.Uuid
  applicant          User                @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  direction          ApplicationDirection
  message            String?
  attachments        Json                @default("[]")
  questionAnswers    Json                @default("[]")
  proposedPay        String?
  proposedSchedule   String?
  proposedConditions String?
  status             ApplicationStatus   @default(PENDING)
  checkInAt          DateTime?
  checkOutAt         DateTime?
  actualHours        Decimal?            @db.Decimal(5, 2)
  appliedAt          DateTime            @default(now())
  respondedAt        DateTime?
  completedAt        DateTime?

  reviews    Review[]
  settlement Settlement?
  chatRoom   ChatRoom?

  @@unique([postId, applicantId, direction])
  @@index([postId, applicantId])
  @@map("applications")
}

model Review {
  id                 String   @id @default(uuid()) @db.Uuid
  applicationId      String   @db.Uuid
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId         String   @db.Uuid
  reviewer           User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId         String   @db.Uuid
  reviewee           User     @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewerRole       String?
  rating             Decimal  @db.Decimal(3, 2)
  punctualityRating  Int?
  workQualityRating  Int?
  comment            String?
  createdAt          DateTime @default(now())

  @@map("reviews")
}

model Settlement {
  id               String           @id @default(uuid()) @db.Uuid
  applicationId    String           @unique @db.Uuid
  application      Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employerId       String           @db.Uuid
  employer         EmployerProfile  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  workerId         String           @db.Uuid
  worker           WorkerProfile    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  grossAmount      Int
  commissionAmount Int
  netAmount        Int
  commissionRate   Decimal          @db.Decimal(5, 2)
  status           SettlementStatus @default(CHECKOUT_PENDING)
  transactionId    String?
  settledAt        DateTime?
  createdAt        DateTime         @default(now())

  @@map("settlements")
}

model ChatRoom {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String?         @unique @db.Uuid
  application   Application?    @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  workerId      String          @db.Uuid
  worker        WorkerProfile   @relation("WorkerChatRooms", fields: [workerId], references: [id], onDelete: Cascade)
  employerId    String          @db.Uuid
  employer      EmployerProfile @relation("EmployerChatRooms", fields: [employerId], references: [id], onDelete: Cascade)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())

  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  id          String          @id @default(uuid()) @db.Uuid
  roomId      String          @db.Uuid
  room        ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId    String          @db.Uuid
  sender      User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  messageType ChatMessageType @default(TEXT)
  content     String
  isRead      Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([roomId, createdAt(sort: Desc)])
  @@map("chat_messages")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  data      Json?
  isRead    Boolean             @default(false)
  channel   NotificationChannel @default(IN_APP)
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model FavoriteWorker {
  id         String          @id @default(uuid()) @db.Uuid
  employerId String          @db.Uuid
  employer   EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  workerId   String          @db.Uuid
  worker     WorkerProfile   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([employerId, workerId])
  @@map("favorite_workers")
}

model UserMedia {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @db.Uuid
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType          MediaType
  originalUrl        String
  thumbnailUrl       String?
  optimizedUrl       String?
  fileSizeBytes      BigInt?
  mimeType           String?
  durationSeconds    Int?
  width              Int?
  height             Int?
  aiModerationStatus ModerationStatus @default(PENDING)
  aiModerationReason String?
  aiAutoCaption      String?
  aiContentSummary   String?
  aiSuggestedTags    Json             @default("[]")
  isPrimary          Boolean          @default(false)
  displayOrder       Int              @default(0)
  status             MediaStatus      @default(PROCESSING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([userId, mediaType])
  @@map("user_media")
}

model PostComment {
  id            String        @id @default(uuid()) @db.Uuid
  postId        String        @db.Uuid
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId      String        @db.Uuid
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId      String?       @db.Uuid
  parent        PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  children      PostComment[] @relation("CommentReplies")
  content       String
  isAuthorReply Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([postId, createdAt(sort: Desc)])
  @@map("post_comments")
}
